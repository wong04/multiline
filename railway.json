{
	"$schema": "https://railway.app/railway.schema.json",
	"build": {
		"builder": "NIXPACKS"
	},
	"deploy": {
		"startCommand": "uv run uvicorn src.server.app:app --host 0.0.0.0 --port $PORT --ws-ping-interval 20 --ws-ping-timeout 20",
		"healthcheckPath": "/healthz",
		"healthcheckTimeout": 300,
		"numReplicas": 1,
		"restartPolicyType": "ON_FAILURE",
		"restartPolicyMaxRetries": 3
	}
}
